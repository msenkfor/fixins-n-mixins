{
  "name": "fixins-n-mixins",
  "version": "0.1.0",
  "main": "expo-router/entry",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@expo-google-fonts/fredoka": "^0.4.1",
    "@expo-google-fonts/nunito": "^0.4.2",
    "@types/jest": "29.5.14",
    "expo": "~57.0.7",
    "expo-constants": "~57.0.6",
    "expo-file-system": "~57.0.1",
    "expo-font": "~57.0.1",
    "expo-haptics": "~57.0.1",
    "expo-image": "~57.0.1",
    "expo-image-manipulator": "~57.0.5",
    "expo-image-picker": "~57.0.5",
    "expo-linear-gradient": "~57.0.1",
    "expo-linking": "~57.0.3",
    "expo-router": "~57.0.7",
    "expo-status-bar": "~57.0.1",
    "jest": "~29.7.0",
    "jest-expo": "~57.0.2",
    "lottie-react-native": "~7.3.8",
    "react": "19.2.7",
    "react-native": "0.86.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-worklets": "0.10.0"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "~19.2.2",
    "react-test-renderer": "^19.2.7",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "test:functions": "deno test supabase/functions/tests/ --allow-env --allow-read"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.ts"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.[jt]s?(x)"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/.gsd/",
      "/supabase/"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/.gsd/"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg|lottie-react-native)"
    ]
  },
  "private": true
}
